# Copy to .env and fill in. .env is gitignored and is read from the bot's
# working directory at startup (python-dotenv), including under systemd.
# Non-secret settings (channels, timezone, AI tuning, calendar) live in config.yaml.

# dev uses BOT_TOKEN_DEV, prod uses BOT_TOKEN
ENV=dev

# Discord bot tokens (Developer Portal -> your app -> Bot -> Reset Token)
BOT_TOKEN=your-production-discord-bot-token
BOT_TOKEN_DEV=your-development-discord-bot-token

# OpenAI API key used for the AI Q&A feature
OPENAI_API_KEY=sk-...

# Path to the Google service-account JSON key (for Google Calendar).
# Share the "Équipe PM" calendar with this service account's email (Viewer).
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

# Optional overrides
# CONFIG_FILE=config.yaml
# DATABASE_NAME=family_bot.db
